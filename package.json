{
  "name": "pumpmind-agent",
  "version": "0.4.2",
  "private": true,
  "description": "Autonomous AI agent for Pump.fun token intelligence, sentiment routing, and on-chain signal execution",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "agent:run": "node apps/cli/dist/index.js run",
    "agent:watch": "node apps/cli/dist/index.js watch"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
